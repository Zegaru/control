{
  "name": "control",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "CONTROL — Local Dev Command Center. One UI to see and manage every dev server across your projects.",
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:daemon": "pnpm --filter @control/daemon dev",
    "dev:ui": "pnpm --filter @control/ui dev",
    "kill:daemon": "node scripts/kill-daemon.mjs",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "lint": "biome check .",
    "start": "pnpm --filter @control/daemon start"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
