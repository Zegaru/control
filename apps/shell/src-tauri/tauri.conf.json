{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Control",
  "mainBinaryName": "Control",
  "version": "0.1.1",
  "identifier": "dev.control.desktop",
  "build": {
    "frontendDist": "../frontend",
    "beforeBuildCommand": {
      "cwd": "../../..",
      "script": "node scripts/stage-runtime.mjs"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CONTROL — Local Dev Command Center",
        "width": 1440,
        "height": 900,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "theme": "Dark",
        "backgroundColor": "#05060a"
      },
      {
        "label": "tray",
        "title": "CONTROL",
        "url": "tray.html",
        "width": 260,
        "height": 276,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "theme": "Dark",
        "backgroundColor": "#05060a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
